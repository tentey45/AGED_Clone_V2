# AI Assistant - Environment Variables Configuration

# Copy this file to .env and replace placeholders with your actual keys.
# .env should NOT be committed to git.

# Groq API Key (Required)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Frontend Configuration (Optional - for local dev defaults)
VITE_API_BASE_URL=http://localhost:8000
